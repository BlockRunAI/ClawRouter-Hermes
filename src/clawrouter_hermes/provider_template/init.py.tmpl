"""ClawRouter model-provider plugin (materialized into ~/.hermes/plugins/model-providers/clawrouter/).

Wires ClawRouter into Hermes' provider registry. The actual proxy URL and
default model are read at import time from
``~/.openclaw/hermes-plugin.json`` (written by the standalone plugin's
supervisor when it negotiates a port). If that file is missing we fall
back to the canonical defaults.

This module is loaded by ``providers/__init__.py`` (Hermes' lazy
discovery), not by the general PluginManager.
"""

from __future__ import annotations

import json
import logging
import os
from pathlib import Path
from typing import Any

from providers import register_provider
from providers.base import ProviderProfile

logger = logging.getLogger(__name__)

_DEFAULT_BASE_URL = "http://127.0.0.1:8402/v1"
_STATE_FILE = Path.home() / ".openclaw" / "hermes-plugin.json"


def _read_base_url() -> str:
    override = os.environ.get("CLAWROUTER_PROXY_URL")
    if override:
        return override.rstrip("/")
    try:
        if _STATE_FILE.is_file():
            data = json.loads(_STATE_FILE.read_text())
            port = int(data.get("port") or 8402)
            return f"http://127.0.0.1:{port}/v1"
    except Exception as exc:
        logger.debug("clawrouter provider: failed reading state file: %s", exc)
    return _DEFAULT_BASE_URL


