class ClawRouterProfile(ProviderProfile):
    """ClawRouter — OpenAI-compatible gateway with x402 micropayments.

    The local proxy handles wallet signing and routing; this profile is a
    thin pointer at http://127.0.0.1:<port>/v1 plus a sensible default
    auxiliary model.
    """

    def build_api_kwargs_extras(
        self,
        *,
        reasoning_config: dict | None = None,
        supports_reasoning: bool = False,
        **ctx: Any,
    ) -> tuple[dict[str, Any], dict[str, Any]]:
        extra_body: dict[str, Any] = {}
        if supports_reasoning and reasoning_config is not None:
            extra_body["reasoning"] = dict(reasoning_config)
        return extra_body, {}


clawrouter = ClawRouterProfile(
    name="clawrouter",
    aliases=("blockrun", "claw"),
    display_name="ClawRouter",
    description="ClawRouter — 55+ models, x402 USDC micropayments (Base + Solana), smart routing",
    signup_url="https://blockrun.ai",
    env_vars=("CLAWROUTER_API_KEY",),
    base_url=_read_base_url(),
    auth_type="api_key",
    fallback_models=_STATIC_FALLBACKS,
    default_aux_model="blockrun/auto",
    default_headers={
        "X-Hermes-Plugin": "clawrouter",
    },
)

register_provider(clawrouter)
